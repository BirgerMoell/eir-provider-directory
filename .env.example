# EIR Provider Directory Environment Variables

# Application Configuration
NEXT_PUBLIC_APP_NAME="EIR Provider Directory"
NEXT_PUBLIC_APP_DESCRIPTION="Comprehensive Swedish healthcare provider database"
NEXT_PUBLIC_APP_URL="https://providers.eir.space"

# Data Source Configuration
DATA_SOURCE_PATH="/Users/birger/Community/eir-chrome-plugin"
ENABLE_FULL_DATASET=true
ENABLE_SAMPLE_DATASET=true

# API Configuration
API_RATE_LIMIT=1000
API_CACHE_TTL=3600

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Monitoring (Optional)  
# SENTRY_DSN=https://your-sentry-dsn

# Development
NODE_ENV=development
PORT=3000